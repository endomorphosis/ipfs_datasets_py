{"schema_version":"legal-ir-external-expert-benchmark-v1","packet_id":"external-expert-conflict-waiver-001","source_text":"A lawyer shall not represent a client if the representation involves a concurrent conflict of interest unless each affected client gives informed consent confirmed in writing.","source_document_id":"model-rule-1.7","expected_ir_families":["deontic","cec","frame_logic"],"citations":[{"citation":"ABA Model Rule 1.7(a)-(b)","source_id":"aba-model-rule-1.7","jurisdiction":"professional-responsibility","url":"https://www.americanbar.org/groups/professional_responsibility/publications/model_rules_of_professional_conduct/rule_1_7_conflict_of_interest_current_clients/","span":{"start":0,"end":158}}],"acceptable_ambiguity":{"allowed":true,"ambiguity_types":["exception_scope","consent_condition"],"optional_families":[],"acceptable_family_alternatives":{"cec":["frame_logic"]},"rationale":"Conflict exceptions may be modeled as counterexample constraints or as frame slots for consent and writing."},"proof_obligations":[{"obligation_id":"po-conflict-prohibition","family":"deontic","statement":"Lawyer is prohibited from representing a client with a concurrent conflict absent an exception.","required":true,"acceptance_criteria":["prohibition modality is preserved","condition names concurrent conflict"]},{"obligation_id":"po-conflict-consent-exception","family":"cec","statement":"Exception requires informed written consent from each affected client.","required":true,"acceptance_criteria":["exception requires consent","writing confirmation is represented"]}],"decompiler_expectations":{"expected_reading":"Lawyer shall not represent conflicted client unless each affected client gives informed consent in writing.","required_terms":["lawyer","shall not represent","conflict","informed consent","writing"],"forbidden_terms":["unconditional permission"],"round_trip_required":true},"reference_ir":{"rules":[{"id":"conflict-rule","modality":"prohibition","subject":"lawyer",
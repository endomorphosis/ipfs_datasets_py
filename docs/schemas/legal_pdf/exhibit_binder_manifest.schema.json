{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/ipfs_datasets_py/legal_pdf/exhibit_binder_manifest.schema.json",
  "title": "Exhibit Binder Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["front_sheet_markdown", "working_dir", "output_pdf", "exhibits"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "family": {
      "type": "string"
    },
    "front_sheet_markdown": {
      "type": "string"
    },
    "working_dir": {
      "type": "string"
    },
    "output_pdf": {
      "type": "string"
    },
    "exhibits_root": {
      "type": "string"
    },
    "court_config": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "case_number": { "type": "string" },
        "court_name": { "type": "string" },
        "state_name": { "type": "string" },
        "contact_block_html": { "type": "string" },
        "caption_left_html": { "type": "string" }
      }
    },
    "exhibits": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "title", "divider_markdown", "cover_markdown"],
        "properties": {
          "code": { "type": "string" },
          "title": { "type": "string" },
          "divider_markdown": { "type": "string" },
          "cover_markdown": { "type": "string" },
          "source": { "type": "string" }
        }
      }
    }
  }
}
